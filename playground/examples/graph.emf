package graph;

@diagram(color="ivory")
@node(label="name", contents="nodes")
class Graph {
	attr String name;
	val Node[*] nodes;
	val Edge[*] edges;
}

@node(label="name")
class Node {
	attr String name;
}

@edge(source="source", target="target", preamble="left to right direction")
class Edge {
	ref Node source;
	ref Node target;
}