package wbs;

class Project {
	attr String name;
	val WP[*] wps;
	val Partner[*] partners;
}

@node(label="name", contents="tasks")
class WP {
	attr String name;
	val Task[*] tasks;
}

@node(label="name", shape="object", contents="partners")
class Task {
    attr String name;
    ref Partner[*] partners;
}

@text(label="name")
class Partner {
	id attr String ~id;
	attr String name;
	// Colors from https://plantuml.com/color
	attr String color = "royalblue";
}