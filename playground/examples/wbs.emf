package wbs;

class Project {
	attr String name;
	val WP[*] wps;
	val Partner[*] partners;
}

class WP {
	attr String name;
	val Task[*] tasks;
}

class Task {
    attr String name;
    ref Partner[*] partners;
}

class Partner {
	id attr String ~id;
	attr String name;
	// Colors from https://plantuml.com/color
	attr String color = "royalblue";
}