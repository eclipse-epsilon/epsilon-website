@namespace(uri="pdl", prefix="")
package pdl;

class Project {
	attr String name;
	val Deliverable[*] deliverables;
}

@node(label="name")
@diagram(color="mintcream")
class Deliverable {
	attr String name;
	attr int due;
	@edge(sourceDecoration="arrow", targetDecoration="none", direction="up", label="leads")
	ref Person lead;
}

@node(label="name")
class Person {
	attr String name;
}